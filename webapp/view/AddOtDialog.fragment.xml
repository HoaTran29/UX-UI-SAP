<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog 
        id="addOtDialog"
        title="Xếp lịch làm việc &amp; OT"
        contentWidth="520px">

        <content>
            <VBox class="sapUiSmallMargin">

                <Label
                    text="Xếp lịch theo"
                    class="sapUiTopMarginSmall"
                    visible="{= !${dialogModel>/isEdit} }"/>

                <SegmentedButton
                    selectedKey="{dialogModel>/AssignMode}"
                    selectionChange=".onAssignModeChange"
                    visible="{= !${dialogModel>/isEdit} }"
                    width="100%">

                    <items>
                        <SegmentedButtonItem key="EMP" text="Nhân viên"/>
                        <SegmentedButtonItem key="DEPT" text="Phòng ban"/>
                    </items>
                </SegmentedButton>

                <Label
                    text="Mã nhân viên"
                    required="true"
                    visible="{= ${dialogModel>/AssignMode} === 'EMP' }"
                    class="sapUiTopMarginSmall"/>

                <Input
                    id="PernrInput"
                    value="{dialogModel>/Pernr}"
                    placeholder="Chọn nhân viên từ search help..."
                    editable="{= !${dialogModel>/isEdit} }"
                    showValueHelp="true"
                    valueHelpRequest=".onPernrInputValueHelpRequest"
                    liveChange=".onPernrInputLiveChange"
                    visible="{= ${dialogModel>/AssignMode} === 'EMP' }"/>

                <Text
                    text="{= ${dialogModel>/EmployeeName} ? ${dialogModel>/EmployeeName} + ' - ' + ${dialogModel>/DeptId} : '' }"
                    visible="{= ${dialogModel>/AssignMode} === 'EMP' &amp;&amp; !!${dialogModel>/EmployeeName} }"
                    class="sapUiTinyMarginTop"/>

                <Label
                    text="Phòng ban"
                    required="true"
                    visible="{= ${dialogModel>/AssignMode} === 'DEPT' }"
                    class="sapUiTopMarginSmall"/>

                <Input
                    id="DeptInput"
                    value="{dialogModel>/DeptId}"
                    placeholder="Chọn phòng ban từ search help..."
                    editable="{= !${dialogModel>/isEdit} }"
                    showValueHelp="true"
                    valueHelpRequest=".onDeptInputValueHelpRequest"
                    liveChange=".onDeptInputLiveChange"
                    visible="{= ${dialogModel>/AssignMode} === 'DEPT' }"/>

                <Text
                    text="{dialogModel>/DeptName}"
                    visible="{= ${dialogModel>/AssignMode} === 'DEPT' &amp;&amp; !!${dialogModel>/DeptName} }"
                    class="sapUiTinyMarginTop"/>

                <Label 
                    text="Khoảng thời gian xếp lịch"
                    required="true"
                    class="sapUiTopMarginSmall"
                    visible="{= !${dialogModel>/isEdit} }"/>

                <DateRangeSelection 
                    dateValue="{dialogModel>/StartDate}"
                    secondDateValue="{dialogModel>/EndDate}"
                    displayFormat="dd/MM/yyyy"
                    visible="{= !${dialogModel>/isEdit} }"/>

                <Label 
                    text="Ngày làm việc"
                    required="true"
                    class="sapUiTopMarginSmall"
                    visible="{dialogModel>/isEdit}"/>

                <DatePicker 
                    dateValue="{dialogModel>/PlanDate}"
                    displayFormat="dd/MM/yyyy"
                    editable="false"
                    visible="{dialogModel>/isEdit}"/>

                <Label text="Ca làm việc" required="true" class="sapUiTopMarginSmall"/>

                <Select 
                    id="shiftSelect"
                    selectedKey="{dialogModel>/ShiftId}"
                    items="{shiftLookupModel>/shifts}"
                    width="100%">

                    <core:Item 
                        key="{shiftLookupModel>ShiftId}"
                        text="{shiftLookupModel>ShiftText}" />
                </Select>

                <Label text="Số giờ OT" class="sapUiTopMarginSmall"/>

                <Input 
                    value="{dialogModel>/OtHours}"
                    type="Number"
                    placeholder="Nhập số giờ OT..." />

            </VBox>
        </content>

        <beginButton>
            <Button 
                text="Lưu dữ liệu"
                type="Emphasized"
                press=".onSaveOtPlan" />
        </beginButton>

        <endButton>
            <Button 
                text="Đóng"
                press=".onCloseAddDialog" />
        </endButton>

    </Dialog>

</core:FragmentDefinition>