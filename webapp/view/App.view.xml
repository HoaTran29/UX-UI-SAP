<mvc:View controllerName="com.app.zu26g13.app.controller.App"
    xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
    xmlns="sap.m"
    xmlns:tnt="sap.tnt">
    
   <Shell id="shellId" appWidthLimited="false"> 
        <App id="appId">
           
        <tnt:ToolPage id="toolPage">
            
            <tnt:header>
                <tnt:ToolHeader id="toolHeader">
                    <Button id="sideNavigationToggleButton" icon="sap-icon://menu2" type="Transparent" press=".onCollapseExpandPress" />
                    <Title id="appTitle" text="Workforce Management Portal" />
                    <ToolbarSpacer id="spacer" />
                    <Button id="btnNotif" icon="sap-icon://bell" type="Transparent" tooltip="Notifications" />
                    <Button id="btnUser" icon="sap-icon://account" type="Transparent" tooltip="User Profile" />
                </tnt:ToolHeader>
            </tnt:header>

            <tnt:sideContent>
                <tnt:SideNavigation id="sideNavigation" itemSelect=".onItemSelect">
                    <tnt:item>
                        <tnt:NavigationList>
                            <tnt:NavigationListItem text="Dashboard" icon="sap-icon://barchart" key="dashboard" />
                            <tnt:NavigationListItem text="Timesheet (In/Out)" icon="sap-icon://history" key="timesheet" />
                            <tnt:NavigationListItem text="Dispute Reports" icon="sap-icon://user-edit" key="dispute" />
                            
                        </tnt:NavigationList>
                    </tnt:item>
                    <tnt:fixedItem>
                        <tnt:NavigationList>
                            <tnt:NavigationListItem text="Master Data" icon="sap-icon://action-settings" expanded="false">
                                
                                <tnt:NavigationListItem id="menuEmployeeConfigId" text="Employees" key="employeeConfig" />
                                <tnt:NavigationListItem text="Schedules" key="schedule" />
                                <tnt:NavigationListItem text="Holidays" key="holiday" />
                                <tnt:NavigationListItem id="navShiftConfig" text="Shift Setup" icon="sap-icon://fob-watch" key="shiftConfig"/>
                            </tnt:NavigationListItem>
                        </tnt:NavigationList>
                    </tnt:fixedItem>
                </tnt:SideNavigation>
            </tnt:sideContent>

            <tnt:mainContents>
                <NavContainer id="pageContainer">
                </NavContainer>
            </tnt:mainContents>

        </tnt:ToolPage>
     </App>
    </Shell>
</mvc:View>