<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <SelectDialog
        id="departmentValueHelpDialog"
        title="Chọn phòng ban"
        search=".onDepartmentValueHelpSearch"
        liveChange=".onDepartmentValueHelpSearch"
        confirm=".onDepartmentValueHelpConfirm"
        cancel=".onDepartmentValueHelpCancel"
        items="{departmentLookupModel>/departments}"
        growing="true"
        growingThreshold="30"
        noDataText="Không tìm thấy phòng ban">

        <StandardListItem
            title="{departmentLookupModel>DeptName}"
            description="{departmentLookupModel>DeptId}"
            type="Active"/>

    </SelectDialog>

</core:FragmentDefinition>