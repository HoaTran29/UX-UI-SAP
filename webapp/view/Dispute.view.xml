<mvc:View
    controllerName="com.app.zu26g13.app.controller.Dispute"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

<Page id="pageDispute" showHeader="false" class="sapUiContentPadding">
        
        <Title id="titleDispute" text="Phê duyệt đơn Report" titleStyle="H2" class="sapUiMediumMarginBottom sapUiMediumMarginTop"/>

        <Table id="disputeTable"
               items="{
                   path: '/Dispute',
                   filters: [{ path: 'Status', operator: 'EQ', value1: 'PENDING' }]
               }"
               growing="true"
               class="sapUiElevationCore3">
            
            <columns>
                <Column id="colEmpId"><Text id="txtEmpId" text="Mã NV" /></Column>
                <Column id="colReqType"><Text id="txtReqType" text="Loại yêu cầu" /></Column>
                <Column id="colWorkDate"><Text id="txtWorkDate" text="Ngày làm việc" /></Column>
                <Column id="colTimeEdit"><Text id="txtTimeEdit" text="Giờ xin sửa (In - Out)" /></Column>
                <Column id="colReason" width="20%"><Text id="txtReason" text="Lý do" /></Column>
                <Column id="colAction" hAlign="Center"><Text id="txtAction" text="Thao tác" /></Column>
            </columns>

            <items>
                <ColumnListItem id="cliDisputeItem">
                    <cells>
                        <ObjectIdentifier id="objEmpId" title="{Pernr}" />
                        <Text id="txtReqTypeVal" text="{RequestType}" />
                        <Text id="txtWorkDateVal" text="{ path: 'WorkDate', type: 'sap.ui.model.type.Date', formatOptions: { pattern: 'dd/MM/yyyy' } }" />
                        <Text id="txtTimeEditVal" text="{ path: 'NewActIn', type: 'sap.ui.model.odata.type.Time' } - { path: 'NewActOut', type: 'sap.ui.model.odata.type.Time' }" />
                        <Text id="txtReasonVal" text="{Reason}" wrapping="true" />
                        
                        <HBox id="hboxActions" justifyContent="Center">
                            <Button id="btnApprove" icon="sap-icon://accept" type="Accept" text="Duyệt" class="sapUiTinyMarginEnd" press=".onApprove"/>
                            <Button id="btnReject" icon="sap-icon://decline" type="Reject" text="Từ chối" press=".onReject"/>
                        </HBox>
                    </cells>
                </ColumnListItem>
            </items>
        </Table>

    </Page>
</mvc:View>