<core:FragmentDefinition 
    xmlns="sap.m" 
    xmlns:core="sap.ui.core" 
    xmlns:f="sap.ui.layout.form">
    
    <Dialog id="editTimesheetDialog" title="Chỉnh sửa giờ In/Out &amp; Xác nhận OT" contentWidth="450px" icon="sap-icon://time-entry-request">
        <content>
            <f:SimpleForm editable="true" layout="ResponsiveGridLayout" labelSpanM="4" emptySpanM="0">
                <f:content>
                    <core:Title text="Thông tin giờ giấc" />
                    
                    <Label text="Giờ In (Thực tế)" />
                    <TimePicker value="{ path: 'ActIn', type: 'sap.ui.model.odata.type.Time' }" displayFormat="HH:mm:ss" change=".onCalculateActualHours" />
                    
                    <Label text="Giờ Out (Thực tế)" />
                    <TimePicker value="{ path: 'ActOut', type: 'sap.ui.model.odata.type.Time' }" displayFormat="HH:mm:ss" change=".onCalculateActualHours" />

                    <core:Title text="Xác nhận Tăng ca (OT)" />
                    
                    <Label text="Trạng thái" />
                    <Text text="Có xác nhận duyệt từ Đơn Report" class="sapUiTinyMarginTop sapThemePositiveText" />
                    
                    <Label text="Số giờ OT" />
                    <StepInput value="{ path: 'OtHours', type: 'sap.ui.model.odata.type.Decimal', constraints: { precision: 4, scale: 2 } }" 
           min="0" max="12" step="0.5" displayValuePrecision="1" description="Giờ" />
                </f:content>
            </f:SimpleForm>
        </content>
        <buttons>
            <Button text="Lưu thay đổi" type="Emphasized" icon="sap-icon://save" press=".onSaveTimesheet" />
            <Button text="Hủy" type="Transparent" icon="sap-icon://sys-cancel" press=".onCancelTimesheet" />
        </buttons>
    </Dialog>
</core:FragmentDefinition>