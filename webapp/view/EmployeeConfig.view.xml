<mvc:View
    id="employeeConfigView"
    controllerName="com.app.zu26g13.app.controller.EmployeeConfig"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:core="sap.ui.core">

    <f:DynamicPage id="dynamicPageId">
        <f:title>
            <f:DynamicPageTitle id="pageTitleId">
                <f:heading>
                    <Title id="mainTitleId" text="Cấu hình nhân viên" />
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>

        <f:header>
            <f:DynamicPageHeader id="dynamicPageHeaderId">

    <HBox
        alignItems="End"
        renderType="Bare"
        class="sapUiSmallMargin">

        <VBox class="sapUiSmallMarginEnd">
            <Label text="Mã nhân viên"/>
            <Input
                id="filterPernr"
                placeholder="Chọn nhân viên..."
                showValueHelp="true"
                valueHelpOnly="true"
                valueHelpRequest=".onPernrInputValueHelpRequest"/>
        </VBox>

        <VBox class="sapUiSmallMarginEnd">
            <Label text="Phòng ban"/>
            <Input
                id="filterDept"
                placeholder="Chọn phòng ban..."
                showValueHelp="true"
                valueHelpOnly="true"
                valueHelpRequest=".onDeptInputValueHelpRequest"/>
        </VBox>

        <Button
            icon="sap-icon://clear-filter"
            tooltip="Xóa bộ lọc"
            type="Transparent"
            press=".onClearFilters"/>

    </HBox>

</f:DynamicPageHeader>
        </f:header>

        <f:content>
            <Table id="employeeTable"
                   items="{path: '/Employee'}"
                   growing="true"
                   growingThreshold="20">
                <headerToolbar>
                    <OverflowToolbar id="tableToolbarId">
                        <Title id="tableTitleId" text="Danh sách nhân viên" level="H2"/>
                        <ToolbarSpacer id="toolbarSpacerId" />
                        <Button id="btnCreateId"
                                text="Tạo mới nhân viên" 
                                icon="sap-icon://add" 
                                type="Emphasized" 
                                press=".onOpenCreateDialog" />
                                
                    </OverflowToolbar>
                </headerToolbar>
                <columns>
    <Column id="colPernr"><Text id="txtColPernr" text="Mã NV " /></Column>
    <Column id="colEname"><Text id="txtColEname" text="Họ và Tên " /></Column>
    <Column id="colCardId"><Text id="txtColCardId" text="Mã thẻ " /></Column>
    <Column id="colDept"><Text id="txtColDept" text="Phòng ban" /></Column>
    <Column id="colRole"><Text id="txtColRole" text="Vai trò" /></Column>
    
    <Column id="colAction" width="12rem" hAlign="Center">
        <Text id="txtColAction" text="Thao tác" />
    </Column>
</columns>
<items>
    <ColumnListItem id="rowTemplateId" vAlign="Middle">
        <cells>
            <Text id="cellPernr" text="{Pernr}" />
            <Text id="cellEname" text="{Ename}" />
            <Text id="cellCardId" text="{CardId}" />
            <ObjectAttribute id="cellDept" text="{DeptName}" />
            <ObjectAttribute id="cellRole" text="{RoleDesc}" />
            
            <HBox id="actionBoxId" alignItems="Center" justifyContent="Center">
                <Button id="btnEditRowId"
                        icon="sap-icon://edit" 
                        text="Sửa"
                        type="Transparent" 
                        press=".onOpenEditDialog" />
                        
                <Button id="btnDeleteRowId"
                        icon="sap-icon://delete" 
                        text="Xóa"
                        type="Reject" 
                        press=".onDeleteEmployee" />
            </HBox>
        </cells>
    </ColumnListItem>
</items>
            </Table>
        </f:content>
    </f:DynamicPage>
</mvc:View>