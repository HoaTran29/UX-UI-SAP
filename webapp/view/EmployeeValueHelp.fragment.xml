<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <SelectDialog
        title="Chọn nhân viên"
        search="onEmployeeValueHelpSearch"
        confirm="onEmployeeValueHelpConfirm"
        cancel="onEmployeeValueHelpCancel"
        items="{employeeLookupModel>/employees}"
        growing="true"
        growingThreshold="30">

        <StandardListItem
            title="{employeeLookupModel>EmployeeName}"
            description="{employeeLookupModel>Pernr}"
            info="{employeeLookupModel>DeptId}"
            type="Active"/>

    </SelectDialog>

</core:FragmentDefinition>