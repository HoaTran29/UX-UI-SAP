<mvc:View
    controllerName="com.app.zu26g13.app.controller.Schedule"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:unified="sap.ui.unified">

    <Page title="Quản Lý Phân Ca (Planning Calendar)" showNavButton="true" navButtonPress=".onNavBack" class="sapUiContentPadding">
        <content>
            <PlanningCalendar
                id="pcSchedule"
                startDate="{calendar>/startDate}"
                viewKey="Day"
                rows="{calendar>/rows}"
                enableAppointmentsDragAndDrop="true"
                appointmentDrop=".onAppointmentDrop">
                
                <toolbarContent>
                    <Title text="Bảng lịch làm việc" titleStyle="H4"/>
                    <ToolbarSpacer/>
                    <Button icon="sap-icon://add" text="Thêm Ca Mới" type="Emphasized"/>
                </toolbarContent>

                <rows>
                    <PlanningCalendarRow
                        title="{calendar>EmployeeName}"
                        text="Phòng ban: {calendar>DeptId}"
                        icon="sap-icon://employee"
                        appointments="{path: 'calendar>appointments', templateShareable: false}">
                        
                        <appointments>
                            <unified:CalendarAppointment
                                startDate="{calendar>TimeIn}"
                                endDate="{calendar>TimeOut}"
                                icon="sap-icon://time-entry-request"
                                title="Ca: {calendar>ShiftId}"
                                text="{calendar>Plant}"
                                type="{= ${calendar>IsOt} === true ? 'Type01' : 'Type08' }" />
                        </appointments>
                        
                    </PlanningCalendarRow>
                </rows>
            </PlanningCalendar>
        </content>
    </Page>
</mvc:View>