<mvc:View 
    controllerName="com.app.zu26g13.app.controller.Schedule"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:unified="sap.ui.unified"
    displayBlock="true">

    <Page id="page" title="Xếp Lịch &amp; OT Nhân Viên">

        <headerContent>
            <Input
                id="HeaderEmployeeSearchInput"
                value="{headerSearchModel>/employeeQuery}"
                placeholder="Tìm/chọn nhân viên..."
                width="260px"
                showValueHelp="true"
                valueHelpRequest=".onHeaderEmployeeValueHelpRequest"
                liveChange=".onHeaderEmployeeLiveChange"
                submit=".onHeaderEmployeeSubmit"
                class="sapUiSmallMarginEnd"/>

            <Input
                id="HeaderDepartmentSearchInput"
                value="{headerSearchModel>/deptQuery}"
                placeholder="Tìm/chọn phòng ban..."
                width="260px"
                showValueHelp="true"
                valueHelpRequest=".onHeaderDepartmentValueHelpRequest"
                liveChange=".onHeaderDepartmentLiveChange"
                submit=".onHeaderDepartmentSubmit"
                class="sapUiSmallMarginEnd"/>

            <Button
                icon="sap-icon://clear-filter"
                type="Transparent"
                tooltip="Xóa bộ lọc"
                press=".onClearHeaderFilters"
                class="sapUiSmallMarginEnd"/>

            <Button 
                icon="sap-icon://add"
                text="Thêm lịch OT"
                type="Emphasized"
                press="onOpenCreateDialog"/>
        </headerContent>

        <content>
            <PlanningCalendar 
                id="idPlanningCalendar"
                viewKey="Week"
                rows="{calendarModel>/employees}"
                appointmentSelect=".onAppointmentSelect">

                <rows>
                    <PlanningCalendarRow 
                        title="{calendarModel>EmployeeName} ({calendarModel>Pernr})"
                        text="{= ${calendarModel>DeptName} ? ${calendarModel>DeptName} + ' - ' + ${calendarModel>DeptId} : ${calendarModel>DeptId} }"
                        appointments="{ path: 'calendarModel>appointments', templateShareable: false }">

                        <appointments>
                            <unified:CalendarAppointment 
                                startDate="{calendarModel>StartDate}"
                                endDate="{calendarModel>EndDate}"
                                title="{calendarModel>AppointmentTitle}"
                                text="{calendarModel>AppointmentText}"
                                tooltip="{calendarModel>AppointmentTooltip}"
                                type="{
                                    parts: [
                                        {path: 'calendarModel>ShiftId'},
                                        {path: 'calendarModel>OtHours'}
                                    ],
                                    formatter: '.formatAppointmentType'
                                }"/>
                        </appointments>

                    </PlanningCalendarRow>
                </rows>
            </PlanningCalendar>
        </content>
    </Page>
</mvc:View>