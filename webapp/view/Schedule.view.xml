<mvc:View 
    controllerName="com.app.zu26g13.app.controller.Schedule"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:unified="sap.ui.unified"
    displayBlock="true">

    <Page id="page" title="Xếp Lịch &amp; OT Nhân Viên">

        <headerContent>
            <SearchField 
                id="HeaderEmployeeSearchField"
                value="{headerSearchModel>/query}"
                placeholder="Tìm theo Tên hoặc Mã NV..."
                search=".onHeaderEmployeeSearch"
                liveChange=".onHeaderEmployeeLiveChange"
                width="300px"
                class="sapUiSmallMarginEnd"/>

            <Button 
                icon="sap-icon://add"
                text="Thêm lịch OT"
                type="Emphasized"
                press="onOpenCreateDialog"/>
        </headerContent>

        <content>
            <PlanningCalendar 
                id="idPlanningCalendar"
                viewKey="Week"
                rows="{calendarModel>/employees}"
                appointmentSelect="onAppointmentSelect">

                <rows>
                    <PlanningCalendarRow 
                        id="idRow"
                        title="{calendarModel>EmployeeName} ({calendarModel>Pernr})"
                        appointments="{ path: 'calendarModel>appointments', templateShareable: false }">

                        <appointments>
                            <unified:CalendarAppointment 
                                id="idAppt"
                                startDate="{calendarModel>StartDate}"
                                endDate="{calendarModel>EndDate}"
                                title="Ca: {calendarModel>ShiftId}"
                                text="OT: {calendarModel>OtHours}h"
                                type="{
                                    parts: [
                                        {path: 'calendarModel>ShiftId'},
                                        {path: 'calendarModel>OtHours'}
                                    ],
                                    formatter: '.formatAppointmentType'
                                }"/>
                        </appointments>

                    </PlanningCalendarRow>
                </rows>
            </PlanningCalendar>
        </content>
    </Page>
</mvc:View>